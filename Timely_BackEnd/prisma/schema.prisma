// ============================================================
// Timely Real Estate — Database Schema v3
// Multi-tenant + invite onboarding + listings + messaging
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  owner
  admin
  consultant
  client
}

enum OrgType {
  residential
  commercial
  property_mgmt
}

enum OrgPlan {
  free
  starter
  professional
  enterprise
}

// ============================================================
// ORGANIZATION
// ============================================================

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  type      OrgType  @default(residential)
  plan      OrgPlan  @default(free)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members       OrgMember[]
  projects      Project[]
  invites       Invite[]
  listings      Listing[]
  feedPosts     TeamFeedPost[]
  emails        EmailOutbox[]
  auditLogs     AuditLog[]
  conversations Conversation[]

  @@map("organizations")
}

// ============================================================
// ORG MEMBER
// ============================================================

model OrgMember {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  organizationId Int      @map("organization_id")
  role           Role     @default(client)
  invitedBy      Int?     @map("invited_by")
  joinedAt       DateTime @default(now()) @map("joined_at")

  user         User         @relation("Memberships", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User?        @relation("InvitedMembers", fields: [invitedBy], references: [id])

  @@unique([userId, organizationId])
  @@map("org_members")
}

// ============================================================
// USER
// ============================================================

model User {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  firstName    String   @map("first_name")
  middleName   String   @default("") @map("middle_name")
  lastName     String   @map("last_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Org memberships
  memberships         OrgMember[]        @relation("Memberships")
  invitedMembers      OrgMember[]        @relation("InvitedMembers")
  sentInvites         Invite[]           @relation("SentInvites")

  // Project relationships
  clientProjects      ClientProject[]    @relation("ClientProjects")
  consultantProjects  ConsultantProject[] @relation("ConsultantProjects")
  clientConsultants   ClientConsultant[] @relation("ClientOfConsultant")
  consultantClients   ClientConsultant[] @relation("ConsultantOfClient")
  createdProjects     Project[]          @relation("ProjectCreator")

  // Activity
  hoursLogs           HoursLog[]
  projectComments     ProjectComment[]
  projectAttachments  ProjectAttachment[]
  teamFeedPosts       TeamFeedPost[]
  teamFeedLikes       TeamFeedLike[]

  // Messaging
  conversationMemberships ConversationMember[]
  directMessages          DirectMessage[]

  @@map("users")
}

// ============================================================
// INVITE
// ============================================================

model Invite {
  id             Int       @id @default(autoincrement())
  token          String    @unique @default(uuid())
  email          String
  organizationId Int       @map("organization_id")
  role           Role      @default(client)
  invitedBy      Int       @map("invited_by")
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("SentInvites", fields: [invitedBy], references: [id])

  @@map("invites")
}

// ============================================================
// PROJECT
// ============================================================

model Project {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  organizationId Int       @map("organization_id")
  name           String
  description    String    @default("")
  status         String    @default("Planning")
  priority       String    @default("Medium")
  budget         Decimal?  @db.Decimal(12, 2)
  dateCreated    DateTime? @map("date_created") @db.Date
  dateDue        DateTime? @map("date_due") @db.Date
  createdBy      Int?      @map("created_by")

  // Property fields
  address      String  @default("")
  city         String  @default("")
  state        String  @default("")
  zip          String  @default("")
  propertyType String  @default("") @map("property_type")
  bedrooms     Int?
  bathrooms    String  @default("")
  sqft         Int?
  lotSize      String  @default("") @map("lot_size")
  yearBuilt    String  @default("") @map("year_built")
  amenities    Json    @default("[]")
  photos       Json    @default("[]")
  videos       Json    @default("[]")
  coverPhotoIndex Int  @default(0) @map("cover_photo_index")

  // Interior details
  stories           Int?
  flooring          String  @default("")
  appliances        Json    @default("[]")
  kitchenFeatures   String  @default("") @map("kitchen_features")
  bathroomFeatures  String  @default("") @map("bathroom_features")
  basement          String  @default("")
  interiorFeatures  Json    @default("[]") @map("interior_features")

  // Construction
  constructionMaterials String @default("") @map("construction_materials")
  roofType              String @default("") @map("roof_type")
  foundationType        String @default("") @map("foundation_type")
  exteriorFeatures      Json   @default("[]") @map("exterior_features")

  // Systems
  heatingType String @default("") @map("heating_type")
  coolingType String @default("") @map("cooling_type")

  // Parking
  garageSpaces  Int?    @map("garage_spaces")
  parkingSpaces Int?    @map("parking_spaces")
  parkingType   String  @default("") @map("parking_type")

  // Financial / Public records
  hoaFee        Decimal? @db.Decimal(10, 2) @map("hoa_fee")
  taxAssessment Decimal? @db.Decimal(14, 2) @map("tax_assessment")
  taxYear       String   @default("") @map("tax_year")
  parcelNumber  String   @default("") @map("parcel_number")
  mlsNumber     String   @default("") @map("mls_number")

  // Listing fields
  listingPrice  Decimal? @db.Decimal(14, 2) @map("listing_price")
  listingStatus String   @default("active") @map("listing_status")
  listingSlug   String?  @unique @map("listing_slug")
  isPublished   Boolean  @default(false) @map("is_published")
  publishedAt   DateTime? @map("published_at")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator             User?               @relation("ProjectCreator", fields: [createdBy], references: [id])
  clientProjects      ClientProject[]
  consultantProjects  ConsultantProject[]
  hoursLogs           HoursLog[]
  comments            ProjectComment[]
  attachments         ProjectAttachment[]
  listings            Listing[]
  priceHistory        PriceHistory[]

  @@map("projects")
}
// ============================================================
// PRICE HISTORY
// ============================================================

model PriceHistory {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  price     Decimal  @db.Decimal(14, 2)
  eventType String   @default("price_change") @map("event_type")
  note      String   @default("")
  date      DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("price_history")
}
// ============================================================
// LISTING
// ============================================================

model Listing {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  projectId      Int       @map("project_id")
  organizationId Int       @map("organization_id")
  title          String
  description    String    @default("")
  price          Decimal?  @db.Decimal(14, 2)
  propertyType   String    @default("") @map("property_type")
  bedrooms       Int?
  bathrooms      Int?
  sqft           Int?
  address        String    @default("")
  city           String    @default("")
  state          String    @default("")
  zip            String    @default("")
  lat            Decimal?  @db.Decimal(10, 7)
  lng            Decimal?  @db.Decimal(10, 7)
  status         String    @default("active")
  photos         Json      @default("[]")
  amenities      Json      @default("[]")
  publishedAt    DateTime? @map("published_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("listings")
}

// ============================================================
// CLIENT <-> PROJECT
// ============================================================

model ClientProject {
  id        Int      @id @default(autoincrement())
  clientId  Int      @map("client_id")
  projectId Int      @map("project_id")
  isCurrent Boolean  @default(true) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")

  client  User    @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([clientId, projectId])
  @@map("client_projects")
}

// ============================================================
// CONSULTANT <-> PROJECT
// ============================================================

model ConsultantProject {
  id           Int      @id @default(autoincrement())
  consultantId Int      @map("consultant_id")
  projectId    Int      @map("project_id")
  createdAt    DateTime @default(now()) @map("created_at")

  consultant User    @relation("ConsultantProjects", fields: [consultantId], references: [id], onDelete: Cascade)
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([consultantId, projectId])
  @@map("consultant_projects")
}

// ============================================================
// CLIENT <-> CONSULTANT
// ============================================================

model ClientConsultant {
  id           Int      @id @default(autoincrement())
  clientId     Int      @map("client_id")
  consultantId Int      @map("consultant_id")
  createdAt    DateTime @default(now()) @map("created_at")

  client     User @relation("ClientOfConsultant", fields: [clientId], references: [id], onDelete: Cascade)
  consultant User @relation("ConsultantOfClient", fields: [consultantId], references: [id], onDelete: Cascade)

  @@unique([clientId, consultantId])
  @@map("client_consultants")
}

// ============================================================
// HOURS LOGS
// ============================================================

model HoursLog {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  projectId    Int      @map("project_id")
  consultantId Int      @map("consultant_id")
  logDate      DateTime @map("log_date") @db.Date
  hours        Decimal  @db.Decimal(5, 2)
  description  String   @default("")
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultant User    @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@map("hours_logs")
}

// ============================================================
// PROJECT COMMENTS
// ============================================================

model ProjectComment {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  projectId   Int      @map("project_id")
  authorId    Int      @map("author_id")
  commentText String   @map("comment_text")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("project_comments")
}

// ============================================================
// PROJECT ATTACHMENTS
// ============================================================

model ProjectAttachment {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  projectId  Int      @map("project_id")
  fileName   String   @map("file_name")
  fileSize   String   @default("") @map("file_size")
  fileType   String   @default("") @map("file_type")
  uploadedBy Int?     @map("uploaded_by")
  fileUrl    String   @default("") @map("file_url")
  createdAt  DateTime @default(now()) @map("created_at")

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User?   @relation(fields: [uploadedBy], references: [id])

  @@map("project_attachments")
}

// ============================================================
// TEAM FEED (org-scoped)
// ============================================================

model TeamFeedPost {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  organizationId Int      @map("organization_id")
  authorId       Int      @map("author_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes        TeamFeedLike[]

  @@map("team_feed_posts")
}

model TeamFeedLike {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post TeamFeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("team_feed_likes")
}

// ============================================================
// EMAIL OUTBOX (org-scoped)
// ============================================================

model EmailOutbox {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  organizationId Int      @map("organization_id")
  toEmail        String   @map("to_email")
  fromEmail      String   @default("noreply@timely.com") @map("from_email")
  subject        String
  body           String   @default("")
  status         String   @default("sent")
  createdAt      DateTime @default(now()) @map("created_at")
  sentAt         DateTime @default(now()) @map("sent_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("emails_outbox")
}

// ============================================================
// AUDIT LOG (org-scoped)
// ============================================================

model AuditLog {
  id             Int      @id @default(autoincrement())
  organizationId Int      @map("organization_id")
  timestamp      DateTime @default(now())
  actionType     String   @map("action_type")
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  performedBy    String   @map("performed_by")
  details        String   @default("")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ============================================================
// CONVERSATIONS (org-scoped messaging)
// ============================================================

model Conversation {
  id             Int      @id @default(autoincrement())
  organizationId Int      @map("organization_id")
  projectId      Int?     @map("project_id")
  title          String   @default("")
  type           String   @default("direct")
  createdBy      Int      @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      ConversationMember[]
  messages     DirectMessage[]

  @@map("conversations")
}

model ConversationMember {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  userId         Int      @map("user_id")
  lastReadAt     DateTime @default(now()) @map("last_read_at")
  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model DirectMessage {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  senderId       Int      @map("sender_id")
  body           String
  type           String   @default("text")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("direct_messages")
}